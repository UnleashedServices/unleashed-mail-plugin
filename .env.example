# unleashed-mail plugin — environment template.
#
# Copy to `.env` (which is gitignored) and fill in real values. This file holds
# PLACEHOLDERS ONLY — never commit real secrets (CI's gitleaks job scans for them).

# Google Cloud project id for Gmail push notifications (the Pub/Sub `watch()` topic +
# subscription). Consumed by the `gmail-api-integration` skill — replace the
# `<your-gcp-project-id>` reference in that skill with this value.
GCP_PROJECT_ID=your-gcp-project-id

# NOTE: the `gemini-review` skill authenticates through the Antigravity/Gemini CLI's own
# OAuth (`~/.gemini/oauth_creds.json`). Do NOT set GEMINI_API_KEY or GOOGLE_CLOUD_PROJECT —
# those switch the CLI to Vertex, which this project deliberately does not use.
